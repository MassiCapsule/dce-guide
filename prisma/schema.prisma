generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AppConfig {
  key   String @id
  value String
}

model Media {
  id                       String   @id @default(cuid())
  name                     String
  description              String   @default("")
  toneDescription          String
  writingStyle             String
  doRules                  String   // JSON string array
  dontRules                String   // JSON string array
  productStructureTemplate String
  defaultProductWordCount  Int      @default(800)
  promptPlan               String   @default("")
  planOutputStructure      String   @default("") // Structure de sortie du plan (format HTML + JSON)
  modelPlan                String   @default("") // modèle IA pour la génération du plan (vide = config globale)
  forbiddenWords           String   @default("") // mots/expressions interdits, JSON string array
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  generatedCards GeneratedProductCard[]
  guides         Guide[]
}

model ProductIntelligence {
  id                 String   @id @default(cuid())
  asin               String
  marketplace        String   @default("amazon.fr")
  productTitle       String   @default("")
  shortTitle         String   @default("")
  productBrand       String   @default("")
  productPrice       String   @default("")
  productImageUrl    String   @default("")
  positioningSummary String   @default("")
  keyFeatures        String   @default("[]")
  detectedUsages     String   @default("[]")
  recurringProblems  String   @default("[]")
  buyerProfiles      String   @default("[]")
  sentimentScore     Float    @default(0)
  strengthPoints     String   @default("[]")
  weaknessPoints     String   @default("[]")
  remarkableQuotes   String   @default("[]")
  rawProductJson     String   @default("{}")
  rawReviewsJson     String   @default("[]")
  reviewCount        Int      @default(0)
  analyzed           Boolean  @default(false)
  analysisPromptTokens     Int    @default(0)
  analysisCompletionTokens Int    @default(0)
  analysisModelUsed        String @default("gpt-4o")
  analysisCost             Float  @default(0)
  scrapingCost             Float  @default(0)
  createdAt          DateTime @default(now())

  generatedCards GeneratedProductCard[]
  guideProducts  GuideProduct[]

  @@unique([asin, marketplace])
}

model GeneratedProductCard {
  id               String   @id @default(cuid())
  asin             String
  keyword          String
  wordCount        Int
  contentHtml      String
  promptUsed       String
  modelUsed        String   @default("gpt-4o")
  tokensUsed       Int      @default(0)
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  generationCost   Float    @default(0)
  createdAt        DateTime @default(now())

  media          Media              @relation(fields: [mediaId], references: [id])
  mediaId        String
  intelligence   ProductIntelligence @relation(fields: [intelligenceId], references: [id])
  intelligenceId String

  guideProduct GuideProduct?
}

// --- Guides d'Achat ---

model Guide {
  id           String @id @default(cuid())
  title        String
  criteria     String @default("")
  status       String @default("draft") // draft|scraping|analyzing|distributing|generating|generating-guide|complete|error
  errorMessage String @default("")
  currentStep  Int    @default(0) // Index du produit en cours (progress)

  mediaId String
  media   Media  @relation(fields: [mediaId], references: [id])

  wordCountMin          Int    @default(0)
  wordCountMax          Int    @default(0)

  serpanticsGuideId     String @default("")
  seoScore              Float?
  seoKeywords           String @default("[]") // JSON: [{ expression, target, current, ok }]
  planHtml              String @default("")
  planJson              String @default("") // JSON structuré du plan
  guideHtml             String @default("")
  guideHtmlV2           String @default("")
  articleSummary        String @default("")
  chapoHtml             String @default("")
  sommaireHtml          String @default("")
  faqHtml               String @default("")
  metaTitle             String @default("")
  metaDescription       String @default("")
  imageCaption          String @default("")
  slug                  String @default("")
  guideWordCount        Int    @default(0)
  guidePromptUsed       String @default("")
  guideModelUsed        String @default("gpt-4o")
  guidePromptTokens     Int    @default(0)
  guideCompletionTokens Int    @default(0)
  guideGenerationCost   Float  @default(0)
  totalCost             Float  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products GuideProduct[]
  keywords GuideKeyword[]
}

model GuideProduct {
  id       String @id @default(cuid())
  position Int // Ordre dans le guide (1-based)

  guideId String
  guide   Guide @relation(fields: [guideId], references: [id], onDelete: Cascade)

  intelligenceId String
  intelligence   ProductIntelligence @relation(fields: [intelligenceId], references: [id])

  generatedCardId String?              @unique
  generatedCard   GeneratedProductCard? @relation(fields: [generatedCardId], references: [id])

  keywordAllocation String @default("[]") // JSON: [{ keyword, targetCount }]

  @@unique([guideId, intelligenceId])
  @@unique([guideId, position])
}

model GuideKeyword {
  id             String @id @default(cuid())
  keyword        String
  minOccurrences Int
  maxOccurrences Int

  guideId String
  guide   Guide @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@unique([guideId, keyword])
}
